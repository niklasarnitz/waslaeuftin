{
  "name": "waslaeuftin",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "bun": "^1.3.14"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:generate": "bun --filter @waslaeuftin/db generate",
    "db:push": "bun --filter @waslaeuftin/db push",
    "db:studio": "bun --filter @waslaeuftin/db studio",
    "dev": "turbo watch dev --continue",
    "dev:web": "turbo watch dev -F @waslaeuftin/web",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "bun x sherif@latest",
    "postinstall": "bun run lint:ws && bun run db:generate",
    "test:api": "bun --filter @waslaeuftin/api test",
    "test:providers": "bun --filter @waslaeuftin/cinema-providers test",
    "test:web": "bun --filter @waslaeuftin/web test",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "build:android:apk": "bun --filter @waslaeuftin/expo build:android:apk",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "catalog:",
    "@turbo/gen": "^2.5.8",
    "@waslaeuftin/prettier-config": "workspace:*",
    "dotenv-cli": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@waslaeuftin/prettier-config",
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "@eslint/js": "^9.38.0",
      "@tailwindcss/postcss": "^4.2.2",
      "@tanstack/react-query": "^5.95.2",
      "@trpc/client": "11.15.0",
      "@trpc/server": "11.15.0",
      "@trpc/tanstack-react-query": "^11.7.1",
      "@types/node": "^25.5.0",
      "eslint": "^9.39.1",
      "prettier": "^3.8.1",
      "tailwindcss": "^4.2.2",
      "typescript": "~6.0.3",
      "typescript-eslint": "^8.46.2",
      "zod": "^4.3.6",
      "@ainias42/js-helper": "^0.9.0",
      "@apollo/client": "^4.1.6",
      "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
      "@radix-ui/react-icons": "^1.3.2",
      "@types/bun": "^1.3.11",
      "@umami/node": "^0.4.0",
      "class-variance-authority": "^0.7.1",
      "dotenv-cli": "^10.0.0",
      "moment-timezone": "^0.6.1",
      "octokit": "^5.0.5",
      "postcss": "^8.5.6",
      "prettier-plugin-tailwindcss": "^0.7.1",
      "superjson": "2.2.3",
      "tailwind-merge": "^3.3.1",
      "xior": "^0.8.3"
    },
    "catalogs": {
      "react19": {
        "@types/react": "~19.2.14",
        "@types/react-dom": "19.2.3",
        "react": "19.2.3",
        "react-dom": "19.2.3"
      }
    }
  }
}
