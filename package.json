{
  "name": "waslaeuftin",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "bun": "^1.3.14"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "bun --filter @acme/auth generate",
    "db:generate": "bun --filter @waslaeuftin/web db:generate",
    "db:push": "bun --filter @waslaeuftin/web db:push",
    "db:studio": "bun --filter @waslaeuftin/web db:studio",
    "dev": "turbo watch dev --continue",
    "dev:web": "turbo watch dev -F @waslaeuftin/web",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "bunx sherif@latest",
    "postinstall": "bun run lint:ws",
    "test:web": "bun --filter @waslaeuftin/web test",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@acme/prettier-config": "*",
    "@turbo/gen": "^2.5.8",
    "dotenv-cli": "^10.0.0",
    "prettier": "catalog:",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*"
    ],
    "catalog": {
      "@better-auth/cli": "1.4.0-beta.9",
      "@better-auth/expo": "1.4.0-beta.9",
      "@eslint/js": "^9.38.0",
      "@tailwindcss/postcss": "^4.2.2",
      "@tailwindcss/vite": "^4.2.2",
      "@tanstack/react-form": "^1.23.8",
      "@tanstack/react-query": "^5.95.2",
      "@trpc/client": "11.15.0",
      "@trpc/server": "11.15.0",
      "@trpc/tanstack-react-query": "^11.7.1",
      "@types/node": "^25.5.0",
      "@vitejs/plugin-react": "5.1.0",
      "better-auth": "1.4.0-beta.9",
      "eslint": "^9.39.1",
      "prettier": "^3.8.1",
      "tailwindcss": "^4.2.2",
      "typescript": "^6.0.2",
      "vite": "7.1.12",
      "zod": "^4.3.6"
    },
    "catalogs": {
      "react19": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "react": "19.2.4",
        "react-dom": "19.2.4"
      }
    }
  }
}
