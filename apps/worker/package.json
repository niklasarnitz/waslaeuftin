{
  "name": "@waslaeuftin/worker",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "bun run src/index.ts",
    "start:once": "bun run src/index.ts --once",
    "dev": "bun run with-env -- bun run src/index.ts --once",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@waslaeuftin/api": "workspace:*",
    "@waslaeuftin/db": "workspace:*",
    "expo-server-sdk": "^6.1.0",
    "node-cron": "^4.3.0"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@waslaeuftin/eslint-config": "workspace:*",
    "@waslaeuftin/prettier-config": "workspace:*",
    "@waslaeuftin/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@waslaeuftin/prettier-config"
}
