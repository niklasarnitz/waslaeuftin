    "find:duplicate:cinemas": "bun run scripts/find-duplicate-cinemas-by-city.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "geocode:cinemas": "bun run scripts/geocode-cinemas-osm.ts",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "start": "bun run with-env -- next start",
    "sync:covers:all": "bun run scripts/update-movies/syncAllMovieCovers.ts",
    "test": "bun test",
    "test:tmdb:confidence": "bun run scripts/update-movies/testTmdbConfidenceScore.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "bun run typecheck --watch",
    "update:movies:all": "bun run scripts/update-movies/updateAllMovies.ts",
    "with-env": "dotenv -e ../../.env --"
  },
