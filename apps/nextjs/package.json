{
  "name": "@waslaeuftin/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run with-env -- next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "db:generate": "bun run with-env -- prisma generate",
    "db:push": "bun run with-env -- prisma db push",
    "db:studio": "bun run with-env -- prisma studio",
    "dev": "bun run with-env -- next dev --turbopack",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "postinstall": "bun run db:generate",
    "start": "bun run with-env -- next start",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
