{
  "name": "@waslaeuftin/expo",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "dev": "expo start --go",
    "dev:android": "expo start --go --android",
    "dev:ios": "expo start --go --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android:apk": "bash scripts/build-android-apk.sh",
    "build:android:playstore": "bash scripts/build-android-playstore.sh",
    "build:ios:altstore": "bash scripts/build-ios-altstore.sh",
    "build:ios:appstore": "bash scripts/build-ios-appstore.sh",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
