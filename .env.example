# Since .env is gitignored, use this file as the local environment template.

# waslaeuftin web app
DATABASE_URL="postgresql://user:password@localhost:5432/waslaeuftin"
GITHUB_TOKEN="your-github-token-here"
TMDB_API_KEY="your-tmdb-api-key"
TMDB_IMAGE_BASE_URL="https://image.tmdb.org/t/p"
TMDB_POSTER_SIZE="w780"
TMDB_MIN_CONFIDENCE_SCORE="0.68"
EXPO_ACCESS_TOKEN="your-expo-access-token"
MINIO_ENDPOINT="https://minio.example.com"
MINIO_REGION="de-01"
MINIO_ACCESS_KEY="your-minio-access-key"
MINIO_SECRET_KEY="your-minio-secret-key"
MINIO_USE_SSL="true"
MINIO_BUCKET="waslaeuftin"
MINIO_MOVIE_COVERS_PREFIX="waslaeuftin/tmdb-covers"
MINIO_PUBLIC_BASE_URL="https://minio.example.com/waslaeuftin"
UMAMI_URL="https://analytics.example.com"
UMAMI_WEBSITE_ID="your-website-id"
UMAMI_VIEW_DEDUPLICATION_SECONDS="300"
