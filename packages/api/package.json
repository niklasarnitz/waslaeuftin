{
  "name": "@waslaeuftin/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./src/server.ts"
    },
    "./internal/*": {
      "types": "./dist/*.d.ts",
      "react-server": "./src/*.ts",
      "browser": "./src/server-only-error.ts",
      "react-native": "./src/server-only-error.ts",
      "default": "./src/*.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "bun test",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@trpc/server": "catalog:",
    "@umami/node": "^0.4.0",
    "@waslaeuftin/db": "workspace:*",
    "@waslaeuftin/validators": "workspace:*",
    "moment-timezone": "^0.6.1",
    "octokit": "^5.0.5",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@waslaeuftin/eslint-config": "workspace:*",
    "@waslaeuftin/prettier-config": "workspace:*",
    "@waslaeuftin/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@waslaeuftin/prettier-config"
}
