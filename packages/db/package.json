{
  "name": "@waslaeuftin/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "generate": "bun run with-env -- prisma generate",
    "push": "bun run with-env -- prisma db push",
    "studio": "bun run with-env -- prisma studio",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0"
  },
  "devDependencies": {
    "@waslaeuftin/eslint-config": "workspace:*",
    "@waslaeuftin/prettier-config": "workspace:*",
    "@waslaeuftin/tsconfig": "workspace:*",
    "dotenv-cli": "^10.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "prisma": "^7.5.0",
    "typescript": "catalog:"
  },
  "prettier": "@waslaeuftin/prettier-config",
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
