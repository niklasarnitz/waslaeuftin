{
  "name": "@waslaeuftin/cinema-providers",
  "private": true,
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/index.d.ts",
      "react-native": "./src/server-only-error.ts",
      "browser": "./src/server-only-error.ts",
      "default": "./src/index.ts"
    },
    "./internal/*": {
      "types": "./dist/*.d.ts",
      "react-server": "./src/*.ts",
      "react-native": "./src/server-only-error.ts",
      "browser": "./src/server-only-error.ts",
      "default": "./src/*.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "bun test",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@ainias42/js-helper": "^0.9.0",
    "@apollo/client": "^4.1.6",
    "@waslaeuftin/db": "workspace:*",
    "@waslaeuftin/validators": "workspace:*",
    "cheerio": "^1.2.0",
    "moment-timezone": "^0.6.1",
    "xior": "^0.8.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@waslaeuftin/eslint-config": "workspace:*",
    "@waslaeuftin/prettier-config": "workspace:*",
    "@waslaeuftin/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@waslaeuftin/prettier-config"
}
